{
  "title": "ArtCube Protocol Genesis Title Anchor",
  "description": "Level 2 inscription establishing the immutable root of trust for an individual artwork. Child of Collection Parent (parent/child).",
  "type": "object",
  "required": [
    "protocol", "inscription_type", "version",
    "record", "object_id_core", "ownership_at_genesis",
    "legal_title_anchor", "intellectual_property"
  ],
  "properties": {
    "protocol": { "const": "artcube" },
    "inscription_type": { "const": "GENESIS_TITLE_ANCHOR" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "record": {
      "type": "object",
      "required": ["asset_id", "object_id_record_date"],
      "properties": {
        "asset_id": { "type": "string" },
        "object_id_record_date": { "type": "string", "format": "date" }
      }
    },
    "object_id_core": {
      "type": "object",
      "required": [
        "type_of_object", "title", "subject", "date_or_period",
        "maker", "materials_and_techniques", "measurements"
      ],
      "properties": {
        "type_of_object": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "date_or_period": { "type": "object" },
        "maker": { "type": "object" },
        "materials_and_techniques": {
          "type": "object",
          "required": ["materials", "techniques"],
          "properties": {
            "materials": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "confirmed"],
                "properties": {
                  "name": { "type": "string" },
                  "confirmed": { "type": "boolean" }
                }
              }
            },
            "techniques": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "confirmed"],
                "properties": {
                  "name": { "type": "string" },
                  "confirmed": { "type": "boolean" }
                }
              }
            }
          }
        },
        "measurements": {
          "type": "object",
          "required": ["dimensions_cm"],
          "properties": {
            "dimensions_cm": {
              "type": "object",
              "properties": {
                "height": { "type": "number" },
                "width": { "type": "number" },
                "depth": { "type": "number" }
              }
            },
            "weight_kg": { "type": "number" }
          }
        },
        "inscriptions_and_markings": { "type": "object" },
        "distinguishing_features": { "type": "object" }
      }
    },
    "ownership_at_genesis": {
      "type": "object",
      "required": ["legal_owner_entity", "physical_custodian"],
      "properties": {
        "legal_owner_entity": {
          "type": "object",
          "required": ["name", "jurisdiction"],
          "properties": {
            "name": { "type": "string" },
            "jurisdiction": { "type": "string" }
          }
        },
        "physical_custodian": {
          "type": "object",
          "required": ["name", "location"],
          "properties": {
            "name": { "type": "string" },
            "location": { "type": "string" }
          }
        }
      }
    },
    "legal_title_anchor": {
      "type": "object",
      "required": ["title_anchor", "governing_law", "hybrid_transfer_rule", "statement"],
      "properties": {
        "title_anchor": { "const": true },
        "governing_law": { "type": "string" },
        "hybrid_transfer_rule": { "type": "string" },
        "statement": { "type": "string" }
      }
    },
    "intellectual_property": {
      "type": "object",
      "required": ["copyright", "moral_rights", "rights_grants"],
      "properties": {
        "copyright": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["OWNED", "LICENSED", "PUBLIC_DOMAIN", "UNKNOWN", "DISPUTED"]
            },
            "copyright_owner": { "type": "object" },
            "copyright_year": { "type": ["integer", "null"] },
            "registration": { "type": "object" }
          }
        },
        "moral_rights": {
          "type": "object",
          "properties": {
            "waived": { "type": "string", "enum": ["YES", "NO", "UNKNOWN"] },
            "attribution_required": { "type": "string", "enum": ["YES", "NO", "UNKNOWN"] },
            "integrity_rights_notes": { "type": ["string", "null"] }
          }
        },
        "rights_grants": {
          "type": "object",
          "required": ["baseline_policy", "granted_to_holder", "not_granted_by_default"],
          "properties": {
            "baseline_policy": { "const": "BASELINE_DISPLAY_RIGHTS" },
            "granted_to_holder": {
              "type": "object",
              "required": ["holder_scope", "rights", "status", "limitations"],
              "properties": {
                "holder_scope": { "const": "ALIGNED_HOLDER" },
                "rights": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "status": { "const": "GRANTED" },
                "limitations": { "type": "object" }
              }
            },
            "not_granted_by_default": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "digital_asset_rights": { "type": "object" },
        "royalties": { "type": "object" },
        "disclosures": { "type": "object" }
      }
    }
  },
  "additionalProperties": false
}
