{
  "title": "ArtCube Protocol Correction Event",
  "description": "Fixes minor errors in previous events. The original event remains on-chain. Child of Genesis (parent/child).",
  "type": "object",
  "required": [
    "protocol", "event_type", "version", "parent_genesis_inscription",
    "effective_date", "previous_event_pointer",
    "corrected_event_pointer", "corrected_fields", "reason"
  ],
  "properties": {
    "protocol": { "const": "artcube" },
    "event_type": { "const": "CORRECTION_EVENT" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "parent_genesis_inscription": { "type": "string" },
    "effective_date": { "type": "string", "format": "date" },
    "previous_event_pointer": { "type": ["string", "null"] },
    "corrected_event_pointer": { "type": "string" },
    "corrected_fields": {
      "type": "object",
      "minProperties": 1
    },
    "reason": { "type": "string" }
  },
  "additionalProperties": false
}
