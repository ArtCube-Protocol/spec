{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ArtCube-Protocol/spec/schemas/events/metadata-update.json",
  "title": "ArtCube Protocol Metadata Update",
  "description": "Records corrections or additions to non-critical metadata. Child of Genesis (parent/child).",
  "type": "object",
  "required": [
    "protocol", "event_type", "version", "parent_genesis_inscription",
    "effective_date", "previous_event_pointer", "created_utc",
    "updated_fields", "reason"
  ],
  "properties": {
    "protocol": { "const": "ACP" },
    "event_type": { "const": "METADATA_UPDATE" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "parent_genesis_inscription": { "type": "string" },
    "effective_date": { "type": "string", "format": "date" },
    "previous_event_pointer": { "type": ["string", "null"] },
    "created_utc": { "type": "string", "format": "date-time" },
    "updated_fields": {
      "type": "object",
      "minProperties": 1
    },
    "reason": { "type": "string" }
  },
  "additionalProperties": false
}
