{
  "title": "ArtCube Protocol Custody Event",
  "description": "Records physical location changes. Custody does not imply title transfer. Child of Genesis (parent/child).",
  "type": "object",
  "required": [
    "protocol", "event_type", "version", "parent_genesis_inscription",
    "effective_date", "previous_event_pointer",
    "custodian", "location"
  ],
  "properties": {
    "protocol": { "const": "artcube" },
    "event_type": { "const": "CUSTODY_EVENT" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "parent_genesis_inscription": { "type": "string" },
    "effective_date": { "type": "string", "format": "date" },
    "previous_event_pointer": { "type": ["string", "null"] },
    "custodian": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "location": {
      "type": "object",
      "properties": {
        "facility": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" }
      }
    },
    "authorization_reference": { "type": "string" }
  },
  "additionalProperties": false
}
