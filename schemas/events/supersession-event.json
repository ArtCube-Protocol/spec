{
  "title": "ArtCube Protocol Supersession Event",
  "description": "Used when a material identity error requires a new Genesis inscription. The old Genesis remains on-chain but is marked as superseded. Child of Genesis (parent/child).",
  "type": "object",
  "required": [
    "protocol", "event_type", "version", "parent_genesis_inscription",
    "effective_date", "previous_event_pointer",
    "new_genesis_inscription", "reason"
  ],
  "properties": {
    "protocol": { "const": "artcube" },
    "event_type": { "const": "SUPERSESSION_EVENT" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "parent_genesis_inscription": { "type": "string" },
    "effective_date": { "type": "string", "format": "date" },
    "previous_event_pointer": { "type": ["string", "null"] },
    "new_genesis_inscription": { "type": "string" },
    "reason": { "type": "string" }
  },
  "additionalProperties": false
}
